APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

BYBIT_TESTNET=true
BYBIT_API_KEY=your_key_here
BYBIT_API_SECRET=your_secret_here
# Position mode for linear: one_way (positionIdx=0) or hedge (1=Buy, 2=Sell). Leave empty to infer from positions.
# Set to hedge if you get "position idx not match position mode" (10001).
# BYBIT_POSITION_MODE=hedge

REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
